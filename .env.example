# ==========================================
# Live2D Multi-Agent Animation System
# Environment Variables Template
# ==========================================

# ==========================================
# API Keys - 请替换为你的实际密钥
# ==========================================

# 通义千问 API Key (用于 Qwen3.7-Max 大模型)
# 获取: https://tongyi.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here

# Google Gemini API Key (用于 Gemini Omni 多模态)
# 获取: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Textoon API Key (用于文本到Live2D建模)
# 获取: https://textoon.ai/
TEXTOON_API_KEY=your_textoon_api_key_here

# ElevenLabs API Key (用于高质量TTS配音)
# 获取: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ==========================================
# A2A Registry Configuration
# ==========================================

# A2A注册中心配置
A2A_REGISTRY_HOST=0.0.0.0
A2A_REGISTRY_PORT=50051
A2A_REGISTRY_AUTH=jwt
A2A_REGISTRY_TLS=true

# JWT 密钥 - 请设置一个安全的随机字符串
# 可以用以下命令生成: openssl rand -hex 32
A2A_JWT_SECRET=your_secure_jwt_secret_here_change_this

# ==========================================
# MCP Gateway Configuration
# ==========================================

# MCP网关配置
MCP_GATEWAY_HOST=0.0.0.0
MCP_GATEWAY_PORT=8080
MCP_VERSION=2025-11-25
MCP_TRANSPORT=streamable-http
MCP_AUTH=per_request

# ==========================================
# Provider Registry
# ==========================================

# 能力路由配置。云端和本地模型都通过 provider registry 接入。
PROVIDER_REGISTRY_PATH=./config/provider_registry.example.json
DEFAULT_PRIVACY_MODE=hybrid

# 本地模型服务示例。按需启动 Ollama、vLLM、LM Studio、llama.cpp 或 ComfyUI。
OLLAMA_ENDPOINT=http://localhost:11434
VLLM_ENDPOINT=http://localhost:8000/v1
LMSTUDIO_ENDPOINT=http://localhost:1234/v1
LLAMACPP_ENDPOINT=http://localhost:8080/v1
COMFYUI_ENDPOINT=http://localhost:8188

# ==========================================
# Live2D Configuration
# ==========================================

# Live2D Cubism SDK版本
CUBISM_SDK_VERSION=5.3.03

# Live2D MCP副本数
LIVE2D_MCP_REPLICAS=3

# 默认分辨率和帧率
DEFAULT_RESOLUTION=1920x1080
DEFAULT_FPS=60

# ==========================================
# Storage Configuration
# ==========================================

# 数据卷路径
MODELS_VOLUME=./models
OUTPUT_VOLUME=./output
LOGS_VOLUME=./logs

# ==========================================
# Resource Limits
# ==========================================

# 最大并发任务数
MAX_CONCURRENT_TASKS=10

# 任务超时时间(秒)
TASK_TIMEOUT=3600

# GPU内存限制
GPU_MEMORY_LIMIT=20G

# ==========================================
# Web UI Configuration
# ==========================================

# Web UI端口
WEB_UI_PORT=3000

# 监控端口
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=change-me

# ==========================================
# Advanced Configuration
# ==========================================

# 是否启用调试模式
DEBUG=false

# 日志级别
LOG_LEVEL=INFO

# 是否启用自动清理
AUTO_CLEANUP=true

# 清理保留天数
CLEANUP_DAYS=7
