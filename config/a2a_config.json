{
  "version": "1.0",
  "registry": {
    "host": "a2a-registry",
    "port": 50051,
    "discovery": "dns+srv",
    "heartbeat_interval": 30,
    "ttl": 300
  },
  "authentication": {
    "method": "jwt",
    "issuer": "live2d-ai-studio",
    "audience": "agents",
    "expiry": 86400
  },
  "agents": [
    {
      "id": "director@studio.example.com",
      "name": "总导演Agent",
      "description": "全局任务编排，将剧本分解为分镜，协调所有Agent工作",
      "endpoint": "http://director-agent:8000",
      "capabilities": ["orchestration", "storyboarding", "task_scheduling"]
    },
    {
      "id": "writer@studio.example.com",
      "name": "编剧Agent",
      "description": "剧本创作、情绪分析、台词生成",
      "endpoint": "http://writer-agent:8000",
      "capabilities": ["script_writing", "emotion_analysis", "dialogue_generation"]
    },
    {
      "id": "modeling@tools.example.com",
      "name": "Live2D建模专家",
      "description": "从文本或图片自动生成高质量Live2D模型，使用Textoon技术",
      "endpoint": "http://modeling-agent:8000",
      "capabilities": ["live2d_modeling", "textoon", "auto_rigging"]
    },
    {
      "id": "animator@tools.example.com",
      "name": "动画导演Agent",
      "description": "根据分镜生成动画片段，自动生成动作序列和表情变化",
      "endpoint": "http://animation-agent:8000",
      "capabilities": ["animation", "motion_generation", "emotion_animation"]
    },
    {
      "id": "voice@tools.example.com",
      "name": "配音Agent",
      "description": "生成情感配音，支持多模态TTS和RVC克隆",
      "endpoint": "http://voice-agent:8000",
      "capabilities": ["tts", "voice_generation", "emotion_tts"]
    },
    {
      "id": "lip_sync@tools.example.com",
      "name": "口型同步Agent",
      "description": "音素对齐，实时嘴型同步，平滑插值",
      "endpoint": "http://lip-sync-agent:8000",
      "capabilities": ["lip_sync", "phoneme_alignment", "viseme_generation"]
    },
    {
      "id": "renderer@tools.example.com",
      "name": "渲染合成Agent",
      "description": "将所有动画片段合成最终视频，添加转场和特效",
      "endpoint": "http://renderer-agent:8000",
      "capabilities": ["video_composition", "rendering", "post_processing"]
    }
  ],
  "task_routing": {
    "strategy": "capability_based",
    "fallback": "round_robin",
    "load_balancing": true
  },
  "observability": {
    "tracing": true,
    "metrics": true,
    "logging": true
  }
}
